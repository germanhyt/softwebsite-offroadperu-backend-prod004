# Copiar a .env.laravel.vps en el VPS (config Laravel, no va en git)
APP_NAME="Offroad Peru Admin"
APP_ENV=production
APP_KEY=base64:CAMBIAR_APP_KEY
APP_DEBUG=false
APP_TIMEZONE=America/Lima

# Mientras el DNS no apunte al VPS:
APP_URL=http://2.24.123.124:8081
ASSET_URL=http://2.24.123.124:8081

# Cuando el DNS esté listo:
# APP_URL=https://admin.offroadperu.com.pe
# ASSET_URL=https://admin.offroadperu.com.pe

APP_LOCALE=es
APP_FALLBACK_LOCALE=en
APP_FAKER_LOCALE=es_PE

LOG_CHANNEL=stack
LOG_LEVEL=error

DB_CONNECTION=mysql
DB_HOST=mysql
DB_PORT=3306
DB_DATABASE=offroadp_db
DB_USERNAME=offroadp_admin
DB_PASSWORD=CAMBIAR_PASSWORD

SESSION_DRIVER=database
SESSION_LIFETIME=120
SESSION_ENCRYPT=false
SESSION_PATH=/
# Vacío hasta tener DNS; con HTTPS poner SESSION_SECURE_COOKIE=true
SESSION_SECURE_COOKIE=false

BROADCAST_CONNECTION=log
FILESYSTEM_DISK=public
QUEUE_CONNECTION=database
CACHE_STORE=database

SANCTUM_STATEFUL_DOMAINS=admin.offroadperu.com.pe,www.offroadperu.com.pe

MAIL_MAILER=log
MAIL_FROM_ADDRESS=ventasoffroadperu@gmail.com
MAIL_FROM_NAME="${APP_NAME}"

IZIPAY_API_KEY=

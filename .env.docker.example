# Copiar a .env en el VPS antes del primer despliegue
APP_NAME="Offroad Peru Admin"
APP_ENV=production
APP_KEY=
APP_DEBUG=false
APP_TIMEZONE=America/Lima
APP_URL=https://admin.offroadperu.com.pe

APP_LOCALE=es
APP_FALLBACK_LOCALE=en
APP_FAKER_LOCALE=es_PE

LOG_CHANNEL=stack
LOG_LEVEL=error

DB_CONNECTION=mysql
DB_HOST=mysql
DB_PORT=3306
DB_DATABASE=offroadperu_db
DB_USERNAME=offroadperu
DB_PASSWORD=CAMBIAR_PASSWORD_DB

SESSION_DRIVER=database
SESSION_LIFETIME=120
SESSION_ENCRYPT=false
SESSION_PATH=/
SESSION_DOMAIN=.offroadperu.com.pe

BROADCAST_CONNECTION=log
FILESYSTEM_DISK=public
QUEUE_CONNECTION=database
CACHE_STORE=database

SANCTUM_STATEFUL_DOMAINS=admin.offroadperu.com.pe,www.offroadperu.com.pe

MAIL_MAILER=log
MAIL_FROM_ADDRESS=ventasoffroadperu@gmail.com
MAIL_FROM_NAME="${APP_NAME}"

IZIPAY_API_KEY=

# Docker Compose (no van dentro de Laravel, solo para docker compose)
MYSQL_ROOT_PASSWORD=CAMBIAR_ROOT_PASSWORD
CADDY_EMAIL=admin@offroadperu.com.pe
